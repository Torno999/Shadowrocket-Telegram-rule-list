# NAME: Meta (Facebook / Instagram / WhatsApp / Messenger / Threads) + Viber
# Примечание: Viber принадлежит Rakuten, а не Meta, добавлен в этот файл по запросу пользователя
# Формат совместим с ShadowRocketSimpleConfig
# Политика (PROXY/DIRECT) задаётся один раз в baseline.conf через RULE-SET,
# внутри .list-файла колонка политики не указывается.

# --- Facebook / Messenger ---
DOMAIN-SUFFIX,cdninstagram.com
DOMAIN-SUFFIX,fb.com
DOMAIN-SUFFIX,fb.me
DOMAIN-SUFFIX,fb.watch
DOMAIN-SUFFIX,fbaddins.com
DOMAIN-SUFFIX,fbcdn.net
DOMAIN-SUFFIX,fbsbx.com
DOMAIN-SUFFIX,fbworkmail.com
DOMAIN-SUFFIX,facebook.com
DOMAIN-SUFFIX,facebook.net
DOMAIN-SUFFIX,m.me
DOMAIN-SUFFIX,messenger.com

# --- Instagram ---
DOMAIN-SUFFIX,ig.me
DOMAIN-SUFFIX,instagram.com

# --- WhatsApp ---
DOMAIN-SUFFIX,whatsapp.com
DOMAIN-SUFFIX,whatsapp.net
DOMAIN-SUFFIX,wa.me

# --- Threads ---
DOMAIN-SUFFIX,threads.net
DOMAIN-SUFFIX,threads.com

# --- Meta общее (VR/Oculus, реклама, разработка) ---
DOMAIN-SUFFIX,meta.com
DOMAIN-SUFFIX,metacdn.com
DOMAIN-SUFFIX,oculus.com
DOMAIN-SUFFIX,oculuscdn.com

# --- Viber ---
DOMAIN-SUFFIX,viber.com
DOMAIN-SUFFIX,vbrdev.com
DOMAIN-SUFFIX,viberpay.com

# --- Ключевые слова ---
DOMAIN-KEYWORD,facebook
DOMAIN-KEYWORD,instagram
DOMAIN-KEYWORD,whatsapp
DOMAIN-KEYWORD,viber

# --- Процессы ---
PROCESS-NAME,com.facebook.Facebook
PROCESS-NAME,com.facebook.Messenger
PROCESS-NAME,com.burbn.instagram
PROCESS-NAME,net.whatsapp.WhatsApp
PROCESS-NAME,com.facebook.katana
PROCESS-NAME,com.facebook.orca
PROCESS-NAME,com.instagram.android
PROCESS-NAME,com.whatsapp
PROCESS-NAME,com.viber.voip
PROCESS-NAME,Viber.exe

