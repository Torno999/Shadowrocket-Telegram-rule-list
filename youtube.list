# NAME: YouTube
# Формат совместим с ShadowRocketSimpleConfig
# Политика (PROXY/DIRECT) задаётся один раз в baseline.conf через RULE-SET,
# внутри .list-файла колонка политики не указывается.

# --- Домены ---
DOMAIN,youtu.be
DOMAIN-SUFFIX,googlevideo.com
DOMAIN-SUFFIX,gvt1.com
DOMAIN-SUFFIX,gvt2.com
DOMAIN-SUFFIX,gvt3.com
DOMAIN-SUFFIX,youtube-nocookie.com
DOMAIN-SUFFIX,youtube.ae
DOMAIN-SUFFIX,youtube.com
DOMAIN-SUFFIX,youtubeeducation.com
DOMAIN-SUFFIX,youtubegaming.com
DOMAIN-SUFFIX,youtubei.googleapis.com
DOMAIN-SUFFIX,youtubekids.com
DOMAIN-SUFFIX,yt.be
DOMAIN-SUFFIX,ytimg.com
DOMAIN-SUFFIX,ytimg.l.google.com

# --- Ключевые слова ---
DOMAIN-KEYWORD,youtube

# --- Процессы ---
PROCESS-NAME,com.google.ios.youtube
PROCESS-NAME,com.google.android.youtube
PROCESS-NAME,YouTube.exe

# --- IPv4 (основные диапазоны Google/YouTube) ---
IP-CIDR,8.8.4.0/24,no-resolve
IP-CIDR,8.8.8.0/24,no-resolve
IP-CIDR,23.236.48.0/20,no-resolve
IP-CIDR,34.64.0.0/10,no-resolve
IP-CIDR,64.233.160.0/19,no-resolve
IP-CIDR,66.102.0.0/20,no-resolve
IP-CIDR,66.249.64.0/19,no-resolve
IP-CIDR,72.14.192.0/18,no-resolve
IP-CIDR,74.125.0.0/16,no-resolve
IP-CIDR,108.177.8.0/21,no-resolve
IP-CIDR,142.250.0.0/15,no-resolve
IP-CIDR,172.217.0.0/16,no-resolve
IP-CIDR,172.253.0.0/16,no-resolve
IP-CIDR,173.194.0.0/16,no-resolve
IP-CIDR,192.178.0.0/15,no-resolve
IP-CIDR,207.223.160.0/20,no-resolve
IP-CIDR,209.85.128.0/17,no-resolve
IP-CIDR,216.58.192.0/19,no-resolve
IP-CIDR,216.239.32.0/19,no-resolve

# --- IPv6 ---
IP-CIDR6,2001:4860::/32,no-resolve
IP-CIDR6,2404:6800::/32,no-resolve
